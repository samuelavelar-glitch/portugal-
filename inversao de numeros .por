programa {
  funcao inicio() {
 real  numeros[10] 
inteiro i

para (i=0; i<10; i++) {

escreva("\n", numeros[1])
leia(numeros[i])
}
para  (i=9 ; i>10 ; i--){
escreva("\n:\n",numeros[1])
leia(numeros[i])
  }
///Faça um programa que peça ao usuário para digitar 10 números reais. Ao final
 //imprima cada valor na ordem inversa à leitura.///
  }
