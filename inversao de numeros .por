programa {
  funcao inicio() {
 real  numeros[10] 
inteiro i

para (i = 0; i < 10; i++) {

escreva("\ndigite um numero", numeros[i])
leia(numeros[i])
}
para  (i = 9 ; i >= 0 ; i--){
escreva("\n:",numeros[i])

  }
///Faça um programa que peça ao usuário para digitar 10 números reais. Ao final
 //imprima cada valor na ordem inversa à leitura.///
  }
}
