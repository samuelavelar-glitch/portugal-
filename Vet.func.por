programa{
inclua biblioteca Util--> u
funcao  vet_1(){
      inteiro vvet[14] , i=0 , j=0 , numero=0 
    		   vvet[i]=0
       	   vvet[j]=0
        para( i=0; i < 114 ;i++){
      	   vvet[i] = i+2
     	 para( j=0 ; j < 114; j++){
     	   vvet[j] = j + 21
      	 	 numero= vvet[i] + vvet[j]
       	  	escreva(numero,"\t")
       }	
   		escreva("\n")
     }
		
}
       
funcao inicio()
{




vet_1()

}




}
