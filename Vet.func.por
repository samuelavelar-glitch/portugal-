programa{
inclua biblioteca Utill--> u
funcao inteiro vet_1(){
      inteiro vvet[] i=0 , j=0 , numero=0 
        para( i=0; i<12 ;i++){
         vvet[i] = i+1
        para( j=0 ; j < 12; j++){
        vvet[j] = j+1
        numero= vvet[i] + vvet[j]
         escreva(numero,"")
       }
     }
}
       
funcao início (){


inteiro vvet [12] i , j

}




}
