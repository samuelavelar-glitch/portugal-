funcao inteiro vet_1(){
      inteiro vvet[] i=0 , j=0 , numero=0 
        para( i=0; i<14 ;i++){
         vvet[i] = i+2
        para( j=0 ; j < 14; j++){
        vvet[j] = j+2
        numero= vvet[i] + vvet[j]
         escreva(numero,"\n")
       }
     }
}
       
