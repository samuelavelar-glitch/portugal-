programa {
  inclua biblioteca Texto --> t

  funcao inicio() {
    cadeia nome, cidade, data_nasc , cidade_curta, nome_curto , ano , senha

    escreva("\nDigite seu nome: ")
    leia(nome)

     nome_curto = t.extrair_subtexto(nome, 0, 3)
    escreva("\nPrimeiras letras do nome: ", nome_curto)

    escreva("\nDigite sua data de nascimento: ")
    leia(data_nasc)

    ano = data_nasc + t.extrair_subtexto(data_nasc, 6, 10)
    escreva("\nAno de nascimento: ", ano)

    escreva("\nDigite sua cidade: ")
    leia(cidade)
    
    cidade_curta = cidade + t.extrair_subtexto(cidade, 0, 2)
    escreva("\nInício da cidade: ", cidade_curta)
   
    senha= nome_curto+ano+cidade_curta
    escreva("\nsua senha é" ,senha)
  }
}
