programa
{
	
	funcao inicio()
	{
	inteiro perigo 
      
     escreva("\ndigite a gravidade do perigo:")
     leia(perigo)
     se (perigo>=9) {
     escreva("\n GRAVE: !")
                      }
     se( perigo==5 ou perigo==6 ou perigo==7 ou perigo==8) { 
      escreva(" \n MODERADO!:")
     }
       se(perigo <=4  ){
        escreva(" \n SEGURO!:")
           }
     
	}
}
